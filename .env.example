PORT=3001
SESSION_SECRET=replace-me-with-a-long-random-string
CORS_ORIGIN=http://localhost:5173
DB_PATH=./data/app.sqlite

# --- 千问 (OpenAI-compatible) ---
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=replace-me
OPENAI_CHAT_MODEL=qwen-vl-plus
OPENAI_GRADING_MODEL=qwen-vl-max
# Optional fallback used when role-specific models are not set:
# OPENAI_MODEL=qwen-vl-plus
OPENAI_TIMEOUT_MS=120000
OPENAI_STREAM_TIMEOUT_MS=0

# --- Gemini (via 智增增 proxy or Google official) ---
# When GEMINI_API_KEY is set, Gemini takes precedence over the OpenAI provider.
# Proxy base_url (智增增): https://api.zhizengzeng.com/google
# Official base_url:       https://generativelanguage.googleapis.com
GEMINI_BASE_URL=https://api.zhizengzeng.com/google
GEMINI_API_KEY=replace-me
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_GRADING_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=120000
GEMINI_STREAM_TIMEOUT_MS=0
# Thinking budget for reasoning models (e.g. gemini-2.5-pro-preview).
# -1 = model default, 0 = disable thinking, N = max thinking tokens.
# Leave unset to use the model's built-in default.
# GEMINI_THINKING_BUDGET=0
